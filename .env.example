# ASVL Environment Configuration

# Application
APP_NAME=ASVL
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/asvl

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM/VL Configuration (qwen3-vl-plus)
LLM_API_KEY=sk-20a0d310c1a0fc3f53f65d5da9b42280
LLM_BASE_URL=https://apis.iflow.cn/v1
LLM_MODEL=qwen3-vl-plus

# Rate Limiter (Critical: API allows only 1 concurrent request)
LLM_MAX_CONCURRENT=1
LLM_REQUEST_TIMEOUT=120
LLM_RETRY_COUNT=3

# Aliyun ASR
ASR_PROVIDER=aliyun
ALIYUN_ASR_APP_KEY=your_app_key
ALIYUN_ASR_ACCESS_KEY=your_access_key
ALIYUN_ASR_SECRET_KEY=your_secret_key
ALIYUN_ASR_REGION=cn-shanghai

# Aliyun OSS
STORAGE_TYPE=oss
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET=asvl-videos

# Video Processing
CLIP_PADDING_SECONDS=2.0
MIN_CLIP_DURATION=5.0
MAX_CLIP_DURATION=300.0

# Cost Control
VL_TOP_K_PERCENT=0.2
MAX_CLIPS_PER_VIDEO=50

# Worker
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_TIME_LIMIT=3600